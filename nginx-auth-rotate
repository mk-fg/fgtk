#!/usr/bin/env python

import pathlib as pl, contextlib as cl, hashlib as hl
import os, sys, re, random, stat, tempfile, fcntl, base64


p_out = lambda *a,**kw: print(*a, **kw, flush=True)
p_err = lambda *a,**kw: print(*a, **kw, file=sys.stderr, flush=True) or 1

class adict(dict):
	def __init__(self, *args, **kws):
		super().__init__(*args, **kws)
		self.__dict__ = self

@cl.contextmanager
def safe_replacement( path, *open_args,
		mode=None, commit=True, xattrs=None, uidgid=None, **open_kws ):
	'Context to atomically replace file-path if tmp.commit is set w/o exceptions'
	path, exists = str(path), None
	if mode is None:
		try: mode = stat.S_IMODE(os.lstat(path).st_mode)
		except FileNotFoundError: exists = False
	if uidgid is False or exists is False or isinstance(uidgid, tuple): pass
	elif uidgid is True or os.geteuid():
		try: uidgid = (st := os.stat(path)).st_uid, st.st_gid
		except FileNotFoundError: pass
	if xattrs is None and getattr(os, 'getxattr', None): # MacOS
		try: xattrs = dict((k, os.getxattr(path, k)) for k in os.listxattr(path))
		except FileNotFoundError: exists = False
		except OSError as err:
			if err.errno != errno.ENOTSUP: raise
	open_kws.update( delete=False,
		dir=os.path.dirname(path), prefix=os.path.basename(path) + '.' )
	if not open_args: open_kws.setdefault('mode', 'w')
	if exists is None: exists = os.path.exists(path)
	with tempfile.NamedTemporaryFile(*open_args, **open_kws) as tmp:
		try:
			if mode is not None: os.fchmod(tmp.fileno(), mode)
			if xattrs: list(os.setxattr(tmp.name, k, v) for k, v in xattrs.items())
			if isinstance(uidgid, tuple): os.fchown(tmp.fileno(), *uidgid)
			tmp.file_path, tmp.file_exists, tmp.commit = path, exists, not commit
			yield tmp
			if not tmp.commit: return
			if not tmp.closed:
				tmp.flush()
				try: os.fdatasync(tmp)
				except AttributeError: pass # MacOS
			tmp = os.rename(tmp.name, path)
		finally:
			try: tmp and os.unlink(tmp.name)
			except FileNotFoundError: pass

def gen_new_auth(src_auth, fmt, max_creds, retries=10_000):
	lines, logins = list(), dict()
	for n, line in enumerate(src_auth):
		lines.append(line.rstrip())
		if m := re.match(f'({fmt.login_re}):', line): logins.setdefault(m[1], list()).append(n)
	while (login := fmt.login.format(**fmt.vars_gen())) in logins:
		if (retries := retries - 1) <= 0: raise OverflowError('Failed to generate unique login')
	lines_rm, logins[login], pw = set(), len(lines), fmt.pw.format(**fmt.vars_gen())
	pw_ssha = pw.encode() + (salt := os.urandom(4))
	pw_ssha = base64.b64encode(hl.sha1(pw_ssha).digest() + salt).decode()
	lines.append(login + ':{SSHA}' + pw_ssha)
	while len(logins) > max_creds:
		login_old = list(logins)[0]; lines_rm.update(logins.pop(login_old))
	for n in sorted(lines_rm, reverse=True): del lines[n]
	return login, pw, lines

def main(args=None):
	import argparse, textwrap
	dd = lambda text: re.sub( r' \t+', ' ',
		textwrap.dedent(text).strip('\n') + '\n' ).replace('\t', '  ')
	parser = argparse.ArgumentParser(
		formatter_class=argparse.RawTextHelpFormatter, description=dd('''
			Generate/replace password in nginx auth_basic_user_file and static html page(s).
			Keeps some number of old credentials in the auth-file,
				uses simplest/weak {SSHA} password scheme there, puts current/latest token into html.
			Intended be used for weak/temp auto-rotating http auth, presented on some page.'''))
	parser.add_argument('auth_file', help=dd('''
		Path to nginx auth_basic_user_file, where credentials are rotated.
		Auth lines are added at the end there, ones matching old login names
			are removed from the top, when number of matches ones goes over specified limit.'''))
	parser.add_argument('-l', '--auth-login', metavar='fmt', default='hooman{nnn}', help=dd('''
		Python string-format for logins that are managed by this script.
		Should contain "n" template-variables, which will be substituted-with/match
			random number with that number of digits (e.g. 3 for {nnn}). Default: %(default)s'''))
	parser.add_argument('-p', '--auth-pw', metavar='fmt', default='token{nnnn}', help=dd('''
		Python string-format for passwords generated by this script.
		Same idea as with -l/--auth-login. Default: %(default)s'''))
	parser.add_argument('-n', '--auth-lines', metavar='N', default=3, help=dd('''
		Total number of login:pw credential lines
			matching -l/--auth-login format to keep in auth_file.
		Lines are added at the end there, ones matching old login names
			are removed from the top, when number them goes over this limit. Default: %(default)s
		Login gets re-generated until it doesn't match any pre-existing line(s) there.'''))
	parser.add_argument('-f', '--html-file', metavar='file', action='append', help=dd('''
		HTML file(s) where all -l/--auth-login and -p/--auth-pw
			patterns are regexp-matched and replaced with latest generated credentials.
		Matching does not look for old/removed creds specifically, just anything
			that looks exactly like login/pw, so make sure to use something unique there.
		At least one replacement for login/pw must be made in every
			specified HTML file, otherwise error is raised instead of changing anything.
		Can be used multiple times to process any number of such files.'''))
	parser.add_argument('-v', '--verbose', action='store_true', help=dd('''
		Print new credentials, new nginx auth file,
			and number of replacements made in HTML file(s).'''))
	parser.add_argument('--dry-run', action='store_true', help=dd('''
		Same as -v/--verbose, but also don't change any actual files, only print info.'''))
	opts = parser.parse_args(sys.argv[1:] if args is None else args)

	nn_max, fmt = 20, adict(login=opts.auth_login, pw=opts.auth_pw)
	fmt.vars_gen = lambda: dict(
		('n'*n, f'{{:0{n}d}}'.format(random.randint(0, 10**n-1))) for n in range(1, nn_max) )
	vars_re = dict(('n'*n, r'\d'*n) for n in range(1, nn_max))
	fmt.login_re, fmt.pw_re = (fmt.format(**vars_re) for fmt in [fmt.login, fmt.pw])
	p_auth, p_htmls = pl.Path(opts.auth_file), list(map(pl.Path, opts.html_file or list()))

	with cl.ExitStack() as ctx:
		src_auth = (cte := ctx.enter_context)(p_auth.open('r+'))
		fcntl.lockf(src_auth, fcntl.LOCK_EX)
		login, pw, auth_lines = gen_new_auth(src_auth, fmt, opts.auth_lines)

		for n, p in enumerate(p_htmls):
			p_htmls[n] = [p, src := cte(p.open('r+')), cte(safe_replacement(p))]
			fcntl.lockf(src, fcntl.LOCK_EX)
		dst_auth = cte(safe_replacement(p_auth))
		for n, (p, src, dst) in enumerate(p_htmls):
			html = src.read()
			for rxn, (new, fmt, rx) in enumerate([
					(login, fmt.login, fmt.login_re), (pw, fmt.pw, fmt.pw_re) ], 1):
				html, rn = re.subn(fr'\b{rx}\b', new, html); p_htmls[n][rxn] = rn
				if rn: continue
				return p_err(f'ERROR: HTML file has no pattern-matches for {fmt!r} [ {p} ]')
			dst.write(html); dst.commit = not opts.dry_run
		dst_auth.write(''.join(f'{line}\n' for line in auth_lines))
		dst_auth.commit = not opts.dry_run

	if opts.verbose or opts.dry_run:
		p_out(f'Generated new login=[ {login} ] pw=[ {pw} ]')
		p_out(f'nginx auth file lines [ {p_auth} ]:')
		for line in auth_lines: p_out(f'  {line}')
		if p_htmls:
			p_out('Replacements in HTML file(s):')
			for p, login_rn, pw_rn in p_htmls: p_out(f'  {p} [ login={login_rn} pw={pw_rn} ]')

if __name__ == '__main__': sys.exit(main())
